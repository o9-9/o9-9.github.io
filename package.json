    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.31.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.9.2"
  },
  "engines": {
