---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 dark:border-slate-800 mt-auto" role="contentinfo">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-6 md:py-8">
      <div class="md:flex md:items-center md:justify-between">
        <nav aria-label="Social media links">
          <ul class="flex justify-center items-center gap-2 mb-4 md:order-1 md:mb-0">
            <li>
              <a
                href="https://twitter.com/xa_"
                rel="me noopener"
                aria-label="Twitter"
                class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center transition-colors"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M22 4.01c-1 .49-1.98.689-3 .99-1.121-1.265-2.783-1.335-4.38-.737S11.977 6.323 12 8v1c-3.245.083-6.135-1.395-8-4 0 0-4.182 7.433 4 11-1.872 1.247-3.739 2.088-6 2 3.308 1.803 6.913 2.423 10.034 1.517 3.58-1.04 6.522-3.723 7.651-7.742a13.8 13.8 0 0 0 .497-3.753c0-.249 1.51-2.772 1.818-4.013z"
                  ></path>
                </svg>
              </a>
            </li>
            <li>
              <a
                href="https://mastodon.social/@9__"
                rel="me noopener"
                aria-label="Mastodon"
                class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center transition-colors"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
                  <g
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                  >
                    <path
                      d="M18.648 15.254C16.832 17.017 12 16.88 12 16.88a18.3 18.3 0 0 1-3.288-.256q1.69 2.977 8.982 2.475c-1.945 2.013-13.598 5.257-13.668-7.636L4 10.309c0-3.036.023-4.115 1.352-5.633C7.023 2.766 12 3.01 12 3.01s4.977-.243 6.648 1.667C19.977 6.195 20 7.274 20 10.31s-.456 4.074-1.352 4.944"
                    ></path>
                    <path
                      d="M12 11.204V8.278C12 7.02 11.105 6 10 6S8 7.02 8 8.278V13m4-4.722C12 7.02 12.895 6 14 6s2 1.02 2 2.278V13"
                    ></path>
                  </g>
                </svg>
              </a>
            </li>
            <li>
              <a
                href="https://instagram.com/cl1v"
                rel="me noopener"
                aria-label="Instagram"
                class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center transition-colors"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
                  <g
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                  >
                    <path d="M4 8a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4z"
                    ></path>
                    <path d="M9 12a3 3 0 1 0 6 0 3 3 0 0 0-6 0m7.5-4.5v.01"></path>
                  </g>
                </svg>
              </a>
            </li>
            <li>
              <a
                href="https://unsplash.com/@o99"
                rel="me noopener"
                aria-label="Unsplash"
                class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center transition-colors"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 11h5v4h6v-4h5v9H4zm5-7h6v4H9z"></path>
                </svg>
              </a>
            </li>
            <li>
              <a
                class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center transition-colors"
                aria-label="GitHub"
                href="https://github.com/o9-9"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"
                  ></path>
                </svg>
              </a>
            </li>
          </ul>
        </nav>

        <div class="text-center md:text-left md:flex md:items-center md:justify-between">
          <blockquote class="hidden md:block text-sm text-gray-700 mr-4 dark:text-slate-400">
            <p>
              "The people who are crazy enough to think they can change the world are the ones who
              do"
            </p>
          </blockquote>

          <div class="text-xs text-gray-500 dark:text-slate-500 mt-4 md:mt-0">
            <p>© {currentYear} o9. All rights reserved.</p>
          </div>
        </div>
      </div>

      <div class="mt-6 text-center md:text-right">
        <nav aria-label="Footer links">
          <ul class="flex flex-wrap justify-center md:justify-end gap-x-6 gap-y-2">
            <li>
              <a
                href="/about"
                class="text-xs text-gray-600 hover:text-gray-900 dark:text-slate-400 dark:hover:text-white transition-colors"
              >
                About
              </a>
            </li>
            <li>
              <a
                href="/contact"
                class="text-xs text-gray-600 hover:text-gray-900 dark:text-slate-400 dark:hover:text-white transition-colors"
              >
                Contact
              </a>
            </li>
            <li>
              <a
                href="/rss.xml"
                class="text-xs text-gray-600 hover:text-gray-900 dark:text-slate-400 dark:hover:text-white transition-colors"
              >
                RSS
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</footer>
