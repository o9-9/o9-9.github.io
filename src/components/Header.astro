---
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;
---

<header
  class="fixed w-full border-b border-gray-200 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-900/80 z-30"
  role="banner"
>
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <div class="flex h-16 items-center justify-between">
      <div class="mr-4 shrink-0">
        <a
          class="flex items-center focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-md"
          href="/"
          aria-label="o9 Home"
        >
          <div class="flex flex-shrink-0 items-center">
            <span class="text-2xl font-bold text-gray-900 dark:text-white">o9</span>
          </div>
        </a>
      </div>

      <nav class="flex flex-1 items-center justify-end" aria-label="Main navigation">
        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
          aria-expanded="false"
          aria-controls="main-nav"
          aria-label="Toggle menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        <ul id="main-nav" class="hidden md:flex items-center justify-end gap-2">
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/"
              aria-current={pathname === '/' ? 'page' : undefined}
            >
              Home
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/repo"
              aria-current={pathname === '/repo' ? 'page' : undefined}
            >
              Repo
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/blog"
              aria-current={pathname === '/blog' ? 'page' : undefined}
            >
              Blog
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/about"
              aria-current={pathname === '/about' ? 'page' : undefined}
            >
              About
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/contact"
              aria-current={pathname === '/contact' ? 'page' : undefined}
            >
              Contact
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/donate"
              aria-current={pathname === '/donate' ? 'page' : undefined}
            >
              Donate
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/supercharge"
              aria-current={pathname === '/supercharge' ? 'page' : undefined}
            >
              Supercharge
            </a>
          </li>
          <li>
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium transition-colors hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="RSS Feed"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"
                ></path><circle cx="5" cy="19" r="1"></circle></svg
              >
            </a>
          </li>
          <li>
            <ThemeToggle />
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <!-- Mobile menu, hidden by default -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 hidden bg-white dark:bg-slate-900 flex-col"
    aria-labelledby="mobile-menu-heading"
  >
    <div
      class="flex h-16 items-center justify-between border-b border-gray-200 dark:border-slate-800 px-4"
    >
      <h2 id="mobile-menu-heading" class="sr-only">Mobile Navigation Menu</h2>
      <div class="flex items-center">
        <span class="text-2xl font-bold text-gray-900 dark:text-white">o9</span>
      </div>
      <button
        id="mobile-menu-close"
        class="p-2 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
        aria-label="Close menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col flex-1 overflow-y-auto">
      <ul class="flex flex-col space-y-4 p-6">
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/"
            aria-current={pathname === '/' ? 'page' : undefined}
          >
            Home
          </a>
        </li>
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/repo"
            aria-current={pathname === '/repo' ? 'page' : undefined}
          >
            Repo
          </a>
        </li>
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/blog"
            aria-current={pathname === '/blog' ? 'page' : undefined}
          >
            Blog
          </a>
        </li>
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/about"
            aria-current={pathname === '/about' ? 'page' : undefined}
          >
            About
          </a>
        </li>
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/contact"
            aria-current={pathname === '/contact' ? 'page' : undefined}
          >
            Contact
          </a>
        </li>
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/donate"
            aria-current={pathname === '/donate' ? 'page' : undefined}
          >
            Donate
          </a>
        </li>
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
            href="/supercharge"
            aria-current={pathname === '/supercharge' ? 'page' : undefined}
          >
            Supercharge
          </a>
        </li>
        <li class="pt-6">
          <div class="flex items-center justify-between">
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center rounded-md px-4 py-2 text-lg font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:hover:bg-gray-800"
              aria-label="RSS Feed"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="mr-2"
              >
                <path d="M4 11a9 9 0 0 1 9 9"></path>
                <path d="M4 4a16 16 0 0 1 16 16"></path>
                <circle cx="5" cy="19" r="1"></circle>
              </svg>
              RSS Feed
            </a>
            <div class="px-4">
              <ThemeToggle isMobile={true} />
            </div>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    const body = document.body;

    if (mobileMenuToggle && mobileMenuClose && mobileMenu) {
      mobileMenuToggle.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        mobileMenu.classList.toggle('flex');
        body.classList.toggle('overflow-hidden');
        mobileMenuToggle.setAttribute('aria-expanded', 'true');
      });

      mobileMenuClose.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
        body.classList.remove('overflow-hidden');
        mobileMenuToggle.setAttribute('aria-expanded', 'false');
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          body.classList.remove('overflow-hidden');
          mobileMenuToggle.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // Handle keyboard navigation and accessibility
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
        body.classList.remove('overflow-hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'false');
        mobileMenuToggle?.focus();
      }
    });
  });
</script>
