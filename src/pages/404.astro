---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found - o9">
  <Header />

  <main class="flex flex-col items-center justify-center min-h-screen pt-24 pb-16">
    <div class="container mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-4 text-gray-900 dark:text-white">404</h1>

      <h2 class="text-2xl md:text-3xl font-medium mb-8 text-gray-700 dark:text-gray-300">
        Page Not Found
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <a
        href="/"
        class="inline-flex items-center px-6 py-3 rounded-lg bg-gray-900 text-white hover:bg-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 transition-colors"
      >
        Back to Home
      </a>
    </div>
  </main>

  <Footer />
</Layout>
