---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact - o9">
  <Header />

  <main id="main-content" class="flex-1 flex flex-col pt-24 pb-16">
    <div class="container mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900 dark:text-white">
        Contact
      </h1>

      <div
        class="bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 p-8 shadow-sm"
      >
        <div class="text-center mb-8">
          <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-2">Email</h2>
          <a
            href="mailto:o9@o9-9.com"
            class="text-xl md:text-2xl font-bold text-blue-600 dark:text-blue-400 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-md px-2 py-1 inline-block"
          >
            o9@o9-9.com
          </a>

          <div class="mt-4 text-gray-600 dark:text-gray-300">
            <p class="mb-2">I value my time, so make it worth it.</p>

            <p>I don't do calls. And no job offers.</p>
          </div>
        </div>

        <div class="border-t border-gray-200 dark:border-slate-700 pt-6 mt-6">
          <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-4 text-center">
            Social Media
          </h2>

          <ul class="flex flex-wrap justify-center gap-4">
            <li>
              <a
                href="https://twitter.com/xa_"
                rel="me noopener"
                class="inline-flex items-center px-4 py-2 rounded-md bg-gray-100 hover:bg-gray-200 dark:bg-slate-700 dark:hover:bg-slate-600 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5 mr-2" aria-hidden="true">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M22 4.01c-1 .49-1.98.689-3 .99-1.121-1.265-2.783-1.335-4.38-.737S11.977 6.323 12 8v1c-3.245.083-6.135-1.395-8-4 0 0-4.182 7.433 4 11-1.872 1.247-3.739 2.088-6 2 3.308 1.803 6.913 2.423 10.034 1.517 3.58-1.04 6.522-3.723 7.651-7.742a13.8 13.8 0 0 0 .497-3.753c0-.249 1.51-2.772 1.818-4.013z"
                  ></path>
                </svg>
                Twitter
              </a>
            </li>
            <li>
              <a
                href="https://github.com/o9-9"
                rel="me noopener"
                class="inline-flex items-center px-4 py-2 rounded-md bg-gray-100 hover:bg-gray-200 dark:bg-slate-700 dark:hover:bg-slate-600 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <svg viewBox="0 0 24 24" class="w-5 h-5 mr-2" aria-hidden="true">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"
                  ></path>
                </svg>
                GitHub
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
