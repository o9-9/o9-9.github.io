---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Donate - o9">
  <Header />

  <main class="flex flex-col min-h-screen pt-24 pb-16">
    <div class="container mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-2 text-center text-gray-900 dark:text-white">
        Donate ❤️
      </h1>

      <p class="text-center mb-12 text-gray-600 dark:text-gray-300">
        I'm a Developer and my work is funded by the community.
        <a
          href="https://github.com/sponsors/o9-9"
          class="text-blue-600 dark:text-blue-400 hover:underline"
          >Read more about me and what I do.</a
        >
      </p>

      <div class="space-y-12">
        <div>
          <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Monthly donations</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a
              href="https://github.com/sponsors/o9-9"
              class="flex items-center p-6 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              <div class="mr-4 text-gray-900 dark:text-white">
                <svg class="w-8 h-8" viewBox="0 0 16 16" fill="currentColor">
                  <path
                    d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white">GitHub Sponsors</h3>
                <p class="text-sm text-gray-600 dark:text-gray-300">Support via GitHub Sponsors</p>
              </div>
            </a>

            <a
              href="https://opencollective.com/o99"
              class="flex items-center p-6 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              <div class="mr-4 text-gray-900 dark:text-white">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-1.56 21.307c-4.492-.703-8.03-4.238-8.748-8.727a10.382 10.382 0 0 1-.138-1.533c0-.659.066-1.303.193-1.927.068-.334.145-.663.237-.986.88.152 1.766.275 2.657.367l.676.058c.095.387.22.764.376 1.13 1.092 2.55 3.647 4.348 6.667 4.348.208 0 .415-.008.619-.024 2.646-.203 4.908-1.968 5.707-4.367.247-.744.375-1.53.375-2.318 0-2.27-1.053-4.378-2.877-5.728-.78-.576-1.677-.987-2.618-1.208.216-.82.332-1.68.332-2.566 0-1.135-.185-2.123-.553-2.955.6.088 1.189.219 1.762.39C17.345 3.337 20.275 7.3 20.275 12c0 5.152-4.147 9.36-9.835 9.307zM10.196 3.075C7.396 3.556 5.02 5.248 3.755 7.7c-.292.578-.535 1.15-.727 1.703-.148-.178-.28-.377-.414-.595C1.91 7.627 1.708 6.095 1.783 4.533c.367.024.742.036 1.122.036 2.345 0 4.917-.523 7.291-1.494zm.561 7.292c0-2.045 1.647-3.699 3.69-3.699 2.043 0 3.69 1.655 3.69 3.699 0 2.044-1.647 3.699-3.69 3.699-2.043 0-3.69-1.655-3.69-3.699z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white">Open Collective</h3>
                <p class="text-sm text-gray-600 dark:text-gray-300">Support via Open Collective</p>
              </div>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">One-time donations</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a
              href="https://www.buymeacoffee.com/9___"
              class="flex items-center p-6 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              <div class="mr-4 text-gray-900 dark:text-white">
                <svg
                  class="w-8 h-8"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.2-1.756.205-.656.004-1.31-.025-1.966-.022-.699.004-1.556-.06-2.095-.58-.475-.458-.54-1.174-.605-1.793l-.731-7.013-.322-3.094c-.037-.351-.286-.695-.678-.678-.336.015-.718.3-.678.679l.228 2.185.949 9.112c.147 1.344 1.174 2.068 2.446 2.272.742.12 1.503.144 2.257.156.966.016 1.942.053 2.892-.122 1.408-.258 2.465-1.198 2.616-2.657.34-3.332.683-6.663 1.024-9.995l.215-2.087a.484.484 0 01.39-.426c.402-.078.787-.212 1.074-.518.455-.488.546-1.124.385-1.766zm-1.478.772c-.145.137-.363.201-.578.233-2.416.359-4.866.54-7.308.46-1.748-.06-3.477-.254-5.207-.498-.17-.024-.353-.055-.47-.18-.22-.236-.111-.71-.054-.995.052-.26.152-.609.463-.646.484-.057 1.046.148 1.526.22.577.088 1.156.159 1.737.212 2.48.226 5.002.19 7.472-.14.45-.06.899-.13 1.345-.21.399-.072.84-.206 1.08.206.166.281.188.657.162.974a.544.544 0 01-.169.364zm-6.159 3.9c-.862.37-1.84.788-3.109.788a5.884 5.884 0 01-1.569-.217l.877 9.004c.065.78.717 1.38 1.5 1.38 0 0 1.243.065 1.658.065.447 0 1.786-.065 1.786-.065.783 0 1.434-.6 1.499-1.38l.94-9.95a3.996 3.996 0 00-1.322-.238c-.826 0-1.491.284-2.26.613z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white">Buy Me A Coffee</h3>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  Buy me a coffee to support my work
                </p>
              </div>
            </a>

            <a
              href="https://www.paypal.me/shno5"
              class="flex items-center p-6 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              <div class="mr-4 text-gray-900 dark:text-white">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M7.076 21.337H2.47c-.413 0-.75-.336-.75-.75v-.007a.75.75 0 0 1 .75-.75H7.076c.413 0 .75.336.75.75v.007a.75.75 0 0 1-.75.75Zm4.781-17.98c.1-.066.215-.106.338-.106h4.601c1.917 0 3.443.465 4.334 1.483.397.465.695 1.031.886 1.681a.753.753 0 0 1-.736.92h-2.153c-.415 0-.75.337-.75.75v.007c0 .413.335.75.75.75h2.25c.605 0 1.135.335 1.391.907.48 1.08.242 2.23-.118 3.235-.547 1.527-1.735 2.781-3.43 3.289-1.125.335-2.274.472-3.43.472h-.362c-.63 0-1.072.415-1.304.984l-1.538 6.148a.75.75 0 0 1-.726.566H9.168a.75.75 0 0 1-.726-.935l.907-3.593c.137-.541.669-.913 1.228-.913h2.871c2.25 0 4.336-.671 5.87-2.04.9-.806 1.593-1.891 1.932-3.185.362-1.37.303-2.533-.166-3.43-.709-1.35-2.134-2.04-4.254-2.04h-4.5a.752.752 0 0 1-.74-.893l.75-3.92a.75.75 0 0 1 .237-.412Z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white">PayPal</h3>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  Send a one-time donation via PayPal
                </p>
              </div>
            </a>

            <a
              href="https://opencollective.com/o99"
              class="flex items-center p-6 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              <div class="mr-4 text-gray-900 dark:text-white">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-1.56 21.307c-4.492-.703-8.03-4.238-8.748-8.727a10.382 10.382 0 0 1-.138-1.533c0-.659.066-1.303.193-1.927.068-.334.145-.663.237-.986.88.152 1.766.275 2.657.367l.676.058c.095.387.22.764.376 1.13 1.092 2.55 3.647 4.348 6.667 4.348.208 0 .415-.008.619-.024 2.646-.203 4.908-1.968 5.707-4.367.247-.744.375-1.53.375-2.318 0-2.27-1.053-4.378-2.877-5.728-.78-.576-1.677-.987-2.618-1.208.216-.82.332-1.68.332-2.566 0-1.135-.185-2.123-.553-2.955.6.088 1.189.219 1.762.39C17.345 3.337 20.275 7.3 20.275 12c0 5.152-4.147 9.36-9.835 9.307zM10.196 3.075C7.396 3.556 5.02 5.248 3.755 7.7c-.292.578-.535 1.15-.727 1.703-.148-.178-.28-.377-.414-.595C1.91 7.627 1.708 6.095 1.783 4.533c.367.024.742.036 1.122.036 2.345 0 4.917-.523 7.291-1.494zm.561 7.292c0-2.045 1.647-3.699 3.69-3.699 2.043 0 3.69 1.655 3.69 3.699 0 2.044-1.647 3.699-3.69 3.699-2.043 0-3.69-1.655-3.69-3.699z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white">Open Collective</h3>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  One-time donation via Open Collective
                </p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
