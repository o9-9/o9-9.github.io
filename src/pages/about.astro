---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About - o9">
  <Header />

  <main class="flex flex-col min-h-screen pt-24 pb-16">
    <div class="container mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900 dark:text-white">
        About o9
      </h1>

      <div class="prose dark:prose-invert max-w-none">
        <p>
          I'm a full-time open-source developer. In 2014, I quit my office job to pursue
          open-source. I'm not backpacking anymore, but I'm still doing open-source all day. In
          early 2018.
        </p>
        <p>My current focus is on powershell development and tools.</p>

        <h2>Links</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
          <div>
            <h3>Contact</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="mailto:o9@o9-9.com"
                  class="flex items-center text-blue-600 dark:text-blue-400 hover:underline"
                >
                  <span>Email</span>
                  <span class="ml-2 text-gray-500 dark:text-gray-400">o9@o9-9.com</span>
                </a>
              </li>
              <li>
                <a
                  href="https://discord.com/users/1146203933811953713"
                  class="flex items-center text-blue-600 dark:text-blue-400 hover:underline"
                >
                  <span>Discord</span>
                </a>
              </li>
            </ul>

            <h3 class="mt-6">Social</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="https://instagram.com/unuvnun"
                  class="flex items-center text-blue-600 dark:text-blue-400 hover:underline"
                >
                  <span>Instagram</span>
                </a>
              </li>
              <li>
                <a
                  href="https://twitter.com/@xa_"
                  class="flex items-center text-blue-600 dark:text-blue-400 hover:underline"
                >
                  <span>Twitter</span>
                </a>
              </li>
              <li>
                <a
                  href="https://bsky.app/profile/o9-9.bsky.social"
                  class="flex items-center text-blue-600 dark:text-blue-400 hover:underline"
                >
                  <span>Bluesky</span>
                </a>
              </li>
              <li>
                <a
                  href="https://mastodon.social/@9__"
