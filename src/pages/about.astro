                >
                  <span>Mastodon</span>
                </a>
              </li>
              <li>
                <a
                  href="https://www.reddit.com/user/o99-"
                  class="flex items-center text-blue-600 dark:text-blue-400 hover:underline"
                >
                  <span>Reddit</span>
                </a>
              </li>
            </ul>

            <h3 class="mt-6">Support</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="https://tellonym.me/9a_"
