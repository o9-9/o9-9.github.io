---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Blog - o9">
  <Header />

  <main class="flex flex-col min-h-screen pt-24 pb-16">
    <div class="container mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900 dark:text-white">
        Blog
      </h1>

      <div class="space-y-8">
        <article
          class="bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 p-6 hover:shadow-md transition-shadow"
        >
          <a href="/supercharge" class="block">
            <h2
              class="text-2xl font-bold mb-2 text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              Powershell = ❤️
            </h2>
            <p class="text-gray-600 dark:text-gray-300 mb-4">
              My Powershell Script is now available on GitHub.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">August 1, 2025</span>
              <span
                class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300"
              >
                PowerShell
              </span>
            </div>
          </a>
        </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
