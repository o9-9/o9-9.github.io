---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="o9 - Full-time Open Source Developer">
  <Header />

  <main id="main-content" class="flex-1 flex items-center justify-center pt-16">
    <div
      class="flex flex-col items-center justify-center text-center px-4 py-16 pt-8 md:pt-0 max-w-2xl mx-auto"
    >
      <!-- o9 profile picture -->
      <div class="mb-6 overflow-hidden rounded-full w-32 h-32 md:w-48 md:h-48 bg-transparent">
        <img
          src="/o9-profile.svg"
          alt="o9 avatar"
          class="w-full h-full object-contain"
          width="192"
          height="192"
          loading="eager"
        />
      </div>

      <!-- Name -->
      <h1 class="text-4xl md:text-5xl font-bold mb-2 text-gray-900 dark:text-white">o9</h1>

      <!-- Title -->
      <h2 class="text-xl md:text-2xl font-medium mb-4 text-gray-700 dark:text-gray-300">
        Full-time Open Source Developer
      </h2>

      <!-- Short intro -->
      <p class="text-base text-gray-600 dark:text-gray-400 mb-8 max-w-lg">
        Building tools and utilities that help developers create amazing software. Focused on
        performance, accessibility, and open source contribution.
      </p>

      <!-- Buttons -->
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/repo"
          class="inline-flex items-center px-5 py-2.5 rounded-lg bg-gray-900 text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-800 focus:ring-offset-2 dark:bg-gray-700 dark:hover:bg-gray-600 dark:focus:ring-gray-600 transition-colors"
        >
          <span>Browse Repositories</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="ml-2 h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 3v18h18"></path>
            <path d="m7 17 4-4 4-4"></path>
            <path d="m7 7 4 4 4 4"></path>
          </svg>
        </a>
        <a
          href="https://github.com/o9-9"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 rounded-lg bg-gray-200 text-gray-900 hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 dark:focus:ring-gray-700 transition-colors"
        >
          <span>GitHub Profile</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="ml-2 h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
          <span class="sr-only">(opens in new tab)</span>
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
